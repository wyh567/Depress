# Copy to `.env` for local round-trip (API server + worker).
# Infra: `docker compose up -d` (Redis :6379, MinIO :9000, bucket depress-artifacts).

# API / worker runtime
PORT=3001
REDIS_HOST=localhost
REDIS_PORT=6379
CORS_ORIGIN=http://localhost:3000

# S3-compatible artifacts (MinIO defaults match docker-compose.yml)
S3_BUCKET=depress-artifacts
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=depress
S3_SECRET_ACCESS_KEY=depress-secret
S3_ENDPOINT=http://localhost:9000

# Web (optional; compile-export defaults to http://localhost:3001)
# NEXT_PUBLIC_API_URL=http://localhost:3001
